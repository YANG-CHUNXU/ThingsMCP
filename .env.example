THINGS_CLOUD_EMAIL=you@example.com
THINGS_CLOUD_PASSWORD=change-me
THINGS_CLOUD_HISTORY_KEY=change-me
THINGS_CLOUD_BASE_URL=https://cloud.culturedcode.com/
THINGS_MCP_AUTH_TOKEN=change-me-to-a-long-random-token
THINGS_MCP_ALLOW_UNAUTHENTICATED=false
THINGS_TIMEZONE=Etc/UTC
THINGS_MCP_APP_ID=com.culturedcode.ThingsMac
THINGS_MCP_PUSH_PRIORITY=5
THINGS_MCP_DB_PATH=~/.cache/things-mcp/entities.sqlite
THINGS_MCP_ALLOWED_HOSTS=127.0.0.1:*,localhost:*,[::1]:*
THINGS_MCP_LOG_PAYLOADS=false
THINGS_MCP_SYNC_TTL_SECONDS=0
